#Actividad 1
while True:
    nombre = input("Ingresa el nombre del cliente: ").strip()
    if nombre.isalpha():
        break
    else:
        print("Error: El nombre solo debe contener letras. Intenta de nuevo.")

while True:
    cant_str = input("Cantidad de productos a comprar: ").strip
    if cant_str.isdigit() and int(cant_str) >0:
     cantidad = int (cant_str)
     break 
    else:
       print("Error: Debes ingresar un numero entero positivo. Intenta de nuevo")

total_sin_descuento = 0
total_con_descuento = 0

for i in range(1, cantidad + 1):
    print(f"\n--- Producto {i} ---")
    while True:
        precio_str = input("Precio del producto: ").strip()
        if precio_str.isdigit():
            precio = int(precio_str)
            break
        else:
            print("Error: El precio debe ser un número entero. Intenta de nuevo.")

while True:
        descuento = input("¿Tiene descuento? S/N: ").strip().lower()
        if descuento == 's' or descuento == 'n':
            break
        else:
            print("Error: Ingresa S para sí o N para no.")
    
total_sin_descuento += precio

if descuento == 's':
        precio_final = precio * 0.9  # 10% de descuento
else:
        precio_final = precio
        total_con_descuento += precio_final
ahorro_total = total_sin_descuento - total_con_descuento
promedio = total_con_descuento / cantidad
print("\n========== RESUMEN DE COMPRA ==========")
print(f"Cliente: {nombre}")
print(f"Cantidad de productos: {cantidad}")
print(f"Total sin descuentos: ${total_sin_descuento}")
print(f"Total con descuentos: ${total_con_descuento:.2f}")
print(f"Ahorro total: ${ahorro_total:.2f}")
print(f"Promedio por producto: ${promedio:.2f}")
print("=======================================")

#Actividad 2
USUARIO_CORRECTO= "alumno"
CLAVE_CORRECTA= "phyton123"
intentos = 0
acceso_concedido = False

while intentos < 3:
    print(f"Intento {intentos + 1}/3 - Usuario: ", end="")
    usuario = input().strip()
    clave = input("Clave: ").strip()
    
    if usuario == USUARIO_CORRECTO and clave == CLAVE_CORRECTA:
        acceso_concedido = True
        print("Acceso concedido.")
        break
    else:
        print("Error: credenciales inválidas.")
        intentos += 1

if not acceso_concedido:
 print("Cuenta bloqueada")
else:
    while True:
        print("/n1) Estado 2) Cambiar clave 3) Mensaje 4) Salir")
        opcion = input("Opcion: ").strip()
        if not opcion.isdigit():
            print("Error: ingrese un número válido.")
            continue
        
        opcion = int(opcion)
        
        if opcion < 1 or opcion > 4:
            print("Error: opción fuera de rango.")
            continue
        
        if opcion == 1:
            print("Estado de inscripción: Inscripto")
            
        elif opcion == 2:
            nueva_clave = input("Nueva clave: ").strip()
            
            if len(nueva_clave) < 6:
                print("Error: mínimo 6 caracteres.")
                continue
            
            confirmar_clave = input("Confirmar clave: ").strip()
            
            if nueva_clave == confirmar_clave:
                CLAVE_CORRECTA = nueva_clave
                print("Clave cambiada exitosamente.")
            else:
                print("Error: las claves no coinciden.")
                
        elif opcion == 3:
            print("Mensaje motivacional: El código que no se rinde, compila.")
            
        elif opcion == 4:
            print("Saliendo del sistema...")
            break
        
#Actividad 3
lunes1 = ""
lunes2 = ""
lunes3 = ""
lunes4 = ""
martes1 = ""
martes2 = ""
martes3 = ""

while True:
    operador = input("Ingresa nombre del operador: ").strip()
    if operador.isalpha():
        break
    else:
        print("Error: El nombre solo debe contener letras.")

while True:
    print("\n===== SISTEMA DE TURNOS =====")
    print("1. Reservar turno")
    print("2. Cancelar turno")
    print("3. Ver agenda del día")
    print("4. Ver resumen general")
    print("5. Cerrar sistema")
    
    opcion = input("Opción: ").strip()
    
    if not opcion.isdigit():
        print("Error: ingrese un número válido.")
        continue
    
    opcion = int(opcion)
    
    if opcion < 1 or opcion > 5:
        print("Error: opción fuera de rango.")
        continue
    
    if opcion == 1:
        while True:
            dia = input("Elegir día (1=Lunes, 2=Martes): ").strip()
            if dia == "1" or dia == "2":
                break
            else:
                print("Error: ingresa 1 o 2.")
        
        while True:
            paciente = input("Nombre del paciente: ").strip()
            if paciente.isalpha():
                break
            else:
                print("Error: solo letras.")
        
        if dia == "1":
            if paciente == lunes1 or paciente == lunes2 or paciente == lunes3 or paciente == lunes4:
                print("Error: el paciente ya tiene turno el Lunes.")
            else:
                if lunes1 == "":
                    lunes1 = paciente
                    print(f"Turno reservado para {paciente} el Lunes.")
                elif lunes2 == "":
                    lunes2 = paciente
                    print(f"Turno reservado para {paciente} el Lunes.")
                elif lunes3 == "":
                    lunes3 = paciente
                    print(f"Turno reservado para {paciente} el Lunes.")
                elif lunes4 == "":
                    lunes4 = paciente
                    print(f"Turno reservado para {paciente} el Lunes.")
                else:
                    print("Error: no hay turnos disponibles el Lunes.")
        
        else:
            if paciente == martes1 or paciente == martes2 or paciente == martes3:
                print("Error: el paciente ya tiene turno el Martes.")
            else:
                if martes1 == "":
                    martes1 = paciente
                    print(f"Turno reservado para {paciente} el Martes.")
                elif martes2 == "":
                    martes2 = paciente
                    print(f"Turno reservado para {paciente} el Martes.")
                elif martes3 == "":
                    martes3 = paciente
                    print(f"Turno reservado para {paciente} el Martes.")
                else:
                    print("Error: no hay turnos disponibles el Martes.")
    
    elif opcion == 2:
        while True:
            dia = input("Elegir día (1=Lunes, 2=Martes): ").strip()
            if dia == "1" or dia == "2":
                break
            else:
                print("Error: ingresa 1 o 2.")
        
        while True:
            paciente = input("Nombre del paciente a cancelar: ").strip()
            if paciente.isalpha():
                break
            else:
                print("Error: solo letras.")
        
        cancelado = False
        
        if dia == "1":
            if lunes1 == paciente:
                lunes1 = ""
                cancelado = True
            elif lunes2 == paciente:
                lunes2 = ""
                cancelado = True
            elif lunes3 == paciente:
                lunes3 = ""
                cancelado = True
            elif lunes4 == paciente:
                lunes4 = ""
                cancelado = True
        else:
            if martes1 == paciente:
                martes1 = ""
                cancelado = True
            elif martes2 == paciente:
                martes2 = ""
                cancelado = True
            elif martes3 == paciente:
                martes3 = ""
                cancelado = True
        
        if cancelado:
            print(f"Turno de {paciente} cancelado.")
        else:
            print("Error: paciente no encontrado en ese día.")
    
    elif opcion == 3:
        while True:
            dia = input("Elegir día (1=Lunes, 2=Martes): ").strip()
            if dia == "1" or dia == "2":
                break
            else:
                print("Error: ingresa 1 o 2.")
        
        if dia == "1":
            print("\n--- AGENDA LUNES ---")
            print(f"Turno 1: {lunes1 if lunes1 != '' else '(libre)'}")
            print(f"Turno 2: {lunes2 if lunes2 != '' else '(libre)'}")
            print(f"Turno 3: {lunes3 if lunes3 != '' else '(libre)'}")
            print(f"Turno 4: {lunes4 if lunes4 != '' else '(libre)'}")
        else:
            print("\n--- AGENDA MARTES ---")
            print(f"Turno 1: {martes1 if martes1 != '' else '(libre)'}")
            print(f"Turno 2: {martes2 if martes2 != '' else '(libre)'}")
            print(f"Turno 3: {martes3 if martes3 != '' else '(libre)'}")
    
    elif opcion == 4:
        ocupados_lunes = 0
        if lunes1 != "": ocupados_lunes += 1
        if lunes2 != "": ocupados_lunes += 1
        if lunes3 != "": ocupados_lunes += 1
        if lunes4 != "": ocupados_lunes += 1
        disponibles_lunes = 4 - ocupados_lunes
        
        ocupados_martes = 0
        if martes1 != "": ocupados_martes += 1
        if martes2 != "": ocupados_martes += 1
        if martes3 != "": ocupados_martes += 1
        disponibles_martes = 3 - ocupados_martes
        
        print("\n===== RESUMEN GENERAL =====")
        print(f"Lunes: {ocupados_lunes} ocupados, {disponibles_lunes} disponibles")
        print(f"Martes: {ocupados_martes} ocupados, {disponibles_martes} disponibles")
        
        if ocupados_lunes > ocupados_martes:
            print("Día con más turnos: Lunes")
        elif ocupados_martes > ocupados_lunes:
            print("Día con más turnos: Martes")
        else:
            print("Empate: ambos días tienen la misma cantidad de turnos")
    
    elif opcion == 5:
        print(f"Cerrando sistema... Operador: {operador}")
        break

#Actividad 4
energia = 100
tiempo = 12
cerraduras_abiertas = 0
alarma = False
codigo_parcial = ""
forzar_seguidas = 0

while True:
    nombre = input("Ingresa nombre del agente: ").strip()
    if nombre.isalpha():
        break
    else:
        print("Error: El nombre solo debe contener letras.")

while energia > 0 and tiempo > 0 and cerraduras_abiertas < 3:
    if alarma == True and tiempo <= 3 and cerraduras_abiertas < 3:
        print("SISTEMA BLOQUEADO POR ALARMA. DERROTA.")
        break
    
    print(f"\n=== BÓVEDA ===")
    print(f"Agente: {nombre}")
    print(f"Energía: {energia} | Tiempo: {tiempo}")
    print(f"Cerraduras abiertas: {cerraduras_abiertas}/3")
    print(f"Alarma: {'ACTIVADA' if alarma else 'DESACTIVADA'}")
    print(f"Código parcial: {codigo_parcial}")
    print("\n1. Forzar cerradura (-20 energía, -2 tiempo)")
    print("2. Hackear panel (-10 energía, -3 tiempo)")
    print("3. Descansar (+15 energía, -1 tiempo)")
    
    while True:
        opcion = input("Opción: ").strip()
        if opcion.isdigit():
            opcion = int(opcion)
            if opcion >= 1 and opcion <= 3:
                break
            else:
                print("Error: opción fuera de rango.")
        else:
            print("Error: ingrese un número válido.")
    
    if opcion == 1:
        forzar_seguidas = forzar_seguidas + 1
        energia = energia - 20
        tiempo = tiempo - 2
        
        if forzar_seguidas >= 3:
            alarma = True
            print("La cerradura se trabó por forzar demasiado. ALARMA ACTIVADA.")
        else:
            if energia < 40:
                print("Riesgo de alarma por baja energía.")
                while True:
                    riesgo = input("Elige un número 1-3: ").strip()
                    if riesgo.isdigit():
                        riesgo = int(riesgo)
                        if riesgo >= 1 and riesgo <= 3:
                            break
                        else:
                            print("Error: debe ser 1, 2 o 3.")
                    else:
                        print("Error: ingrese un número válido.")
                
                if riesgo == 3:
                    alarma = True
                    print("Se activó la alarma por riesgo.")
            
            if not alarma:
                cerraduras_abiertas = cerraduras_abiertas + 1
                print("Cerradura forzada con éxito.")
    
    elif opcion == 2:
        forzar_seguidas = 0
        energia = energia - 10
        tiempo = tiempo - 3
        
        print("Hackeando panel...")
        for paso in range(4):
            codigo_parcial = codigo_parcial + "A"
            print(f"Progreso {paso + 1}/4: {codigo_parcial}")
        
        if len(codigo_parcial) >= 8 and cerraduras_abiertas < 3:
            cerraduras_abiertas = cerraduras_abiertas + 1
            print("Código completo. Cerradura abierta automáticamente.")
    
    elif opcion == 3:
        forzar_seguidas = 0
        energia = energia + 15
        if energia > 100:
            energia = 100
        tiempo = tiempo - 1
        
        if alarma:
            energia = energia - 10
            print("Descansaste pero la alarma te drenó energía extra.")
        else:
            print("Descansaste y recuperaste energía.")

if cerraduras_abiertas == 3:
    print("\n=== VICTORIA ===")
    print(f"{nombre} abrió las 3 cerraduras. Bóveda abierta.")
elif energia <= 0:
    print("\n=== DERROTA ===")
    print("Te quedaste sin energía.")
elif tiempo <= 0:
    print("\n=== DERROTA ===")
    print("Se acabó el tiempo.")

#Actividad 5
import random

while True:
    nombre = input("Ingresa el nombre del Gladiador: ").strip()
    if nombre.isalpha():
        break
    else:
        print("Error: Solo se permiten letras")

hp_jugador = 100
hp_enemigo = 100
pociones = 3
ataque_base = 15
juego_activo = True
turno_jugador = True

print(f"\n¡Bienvenido {nombre}!")
print(f"Tu HP: {hp_jugador} | HP Enemigo: {hp_enemigo} | Pociones: {pociones}")

while juego_activo:
    if turno_jugador:
        print(f"\n--- TU TURNO ---")
        print(f"Tu HP: {hp_jugador} | Enemigo HP: {hp_enemigo} | Pociones: {pociones}")
        print("1. Atacar")
        print("2. Usar poción")
        print("3. Ataque fuerte")
        
        while True:
            opcion = input("Elige acción: ").strip()
            if opcion.isdigit():
                opcion = int(opcion)
                if opcion >= 1 and opcion <= 3:
                    break
                else:
                    print("Error: opción fuera de rango.")
            else:
                print("Error: ingrese un número válido.")
        
        if opcion == 1:
            critico = random.randint(1, 10)
            if critico <= 2:
                dano = float(ataque_base) * 1.5
                print(f"¡GOLPE CRÍTICO! Infliges {dano:.1f} de daño.")
            else:
                dano = float(ataque_base)
                print(f"Infliges {dano:.1f} de daño.")
            hp_enemigo = int(hp_enemigo - dano)
            
        elif opcion == 2:
            if pociones > 0:
                curacion = 30
                hp_jugador = hp_jugador + curacion
                if hp_jugador > 100:
                    hp_jugador = 100
                pociones = pociones - 1
                print(f"Usaste una poción. Recuperas {curacion} HP. Te quedan {pociones} pociones.")
            else:
                print("No te quedan pociones. Pierdes el turno.")
                
        elif opcion == 3:
            acierto = random.randint(1, 10)
            if acierto <= 7:
                dano = float(ataque_base) * 2.0
                print(f"¡ATAQUE FUERTE ACERTÓ! Infliges {dano:.1f} de daño.")
                hp_enemigo = int(hp_enemigo - dano)
            else:
                print("¡El ataque fuerte falló! No infliges daño.")
        
        turno_jugador = False
        
    else:
        print(f"\n--- TURNO ENEMIGO ---")
        accion_enemigo = random.randint(1, 3)
        
        if accion_enemigo == 1:
            critico = random.randint(1, 10)
            if critico <= 2:
                dano = float(12) * 1.5
                print(f"¡El enemigo hace GOLPE CRÍTICO! Recibes {dano:.1f} de daño.")
            else:
                dano = float(12)
                print(f"El enemigo te inflige {dano:.1f} de daño.")
            hp_jugador = int(hp_jugador - dano)
            
        elif accion_enemigo == 2:
            if hp_enemigo < 70:
                curacion = 25
                hp_enemigo = hp_enemigo + curacion
                if hp_enemigo > 100:
                    hp_enemigo = 100
                print(f"El enemigo usa poción y recupera {curacion} HP.")
            else:
                dano = float(10)
                hp_jugador = int(hp_jugador - dano)
                print(f"El enemigo ataca. Recibes {dano:.1f} de daño.")
                
        elif accion_enemigo == 3:
            acierto = random.randint(1, 10)
            if acierto <= 6:
                dano = float(20) * 1.0
                print(f"¡El enemigo carga un ATAQUE FUERTE! Recibes {dano:.1f} de daño.")
                hp_jugador = int(hp_jugador - dano)
            else:
                print("¡El ataque fuerte del enemigo falló!")
        
        turno_jugador = True
    
    if hp_jugador <= 0:
        hp_jugador = 0
        juego_activo = False
        print(f"\n=== DERROTA ===")
        print(f"{nombre} ha caído en combate. HP: {hp_jugador}")
    elif hp_enemigo <= 0:
        hp_enemigo = 0
        juego_activo = False
        print(f"\n=== VICTORIA ===")
        print(f"¡{nombre} ha derrotado al enemigo! HP restante: {hp_jugador}")

print("\nJuego terminado.")